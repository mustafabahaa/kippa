{
  "name": "kippa-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "app",
    "functions"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=app",
    "build": "npm run build --workspace=app",
    "preview": "npm run preview --workspace=app",
    "typecheck": "npm run typecheck --workspace=app",
    "lint": "npm run lint --workspace=app",
    "test": "npm run test --workspace=app",
    "test:watch": "npm run test:watch --workspace=app",
    "functions:build": "npm run build --workspace=functions",
    "functions:test": "npm run test --workspace=functions",
    "deploy": "npm run build && firebase deploy",
    "deploy:web": "npm run build && firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:firebase": "firebase deploy --project YOUR_FIREBASE_PROJECT_ID"
  }
}
